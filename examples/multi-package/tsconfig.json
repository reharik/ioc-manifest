{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@example/lib-contracts/types/LoggingService": [
        "./packages/lib-contracts/src/types/LoggingService.ts"
      ],
      "@example/lib-contracts/*": ["./packages/lib-contracts/src/*"]
    }
  }
}
