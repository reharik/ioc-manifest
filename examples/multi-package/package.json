{
  "name": "example-multi-package",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "gen": "node scripts/gen.mjs",
    "typecheck": "tsc -p packages/app/tsconfig.json",
    "validate": "node ../../dist/cli/ioc.js validate -c ./packages/app/src/ioc.config.ts",
    "start": "tsx packages/app/src/bootstrap.ts",
    "typecheck:broken-expect-fail": "node scripts/expect-broken-typecheck.mjs",
    "validate:broken-expect-fail": "node scripts/expect-validate-broken.mjs",
    "full": "npm run gen && npm run validate && npm run typecheck && npm run start && npm run typecheck:broken-expect-fail && npm run validate:broken-expect-fail"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.0.0"
  }
}
